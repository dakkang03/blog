---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';

type Heading = { depth: number; slug: string; text: string };

type Props = CollectionEntry<'blog'>['data'] & {
  slug?: string;
  lang?: string;
  headings?: Heading[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
  relatedPosts?: { slug: string; title: string; description: string; date: Date }[];
};

const {
  title, description, pubDate, updatedDate, heroImage,
  slug, lang = 'en', headings = [],
  prevPost, nextPost, relatedPosts = [],
  tags, category,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={title} description={description} slug={slug}>
  <div class="post-wrap">

    <!-- 본문 -->
    <article class="prose">
      <div class="post-header">
        <h1>{title}</h1>
        <p class="post-date">
          <FormattedDate date={pubDate} />
          {updatedDate && (
            <span class="updated"> · Updated <FormattedDate date={updatedDate} /></span>
          )}
        </p>
      </div>

      {heroImage && (
        <Image class="hero-image" width={1020} height={510} src={heroImage} alt="" />
      )}

      <slot />

      <!-- 카테고리 + 태그 -->
      <div class="post-meta">
        {category && (
          <div class="meta-row">
            <span class="meta-icon">&#9645;</span>
            <a href={`${base}/${lang}/category/${category}`} class="meta-link">
              {category.toUpperCase()}
            </a>
          </div>
        )}
        {tags && tags.length > 0 && (
          <div class="meta-row">
            <span class="meta-icon">&#9671;</span>
            {tags.map(tag => (
              <a href={`${base}/${lang}/tag/${tag}`} class="tag-link">#{tag}</a>
            ))}
          </div>
        )}
      </div>

      <!-- 이전글 / 다음글 -->
      <nav class="post-nav">
        <div class="nav-item prev">
          {prevPost ? (
            <a href={`${base}/${lang}/blog/${prevPost.slug}/`}>
              <span class="nav-label">&#8592; 이전글</span>
              <span class="nav-title">{prevPost.title}</span>
            </a>
          ) : <span class="nav-empty" />}
        </div>
        <div class="nav-item next">
          {nextPost ? (
            <a href={`${base}/${lang}/blog/${nextPost.slug}/`}>
              <span class="nav-label">다음글 &#8594;</span>
              <span class="nav-title">{nextPost.title}</span>
            </a>
          ) : <span class="nav-empty" />}
        </div>
      </nav>

      <!-- 관련 포스트 -->
      {relatedPosts.length > 0 && (
        <section class="related">
          <p class="related-label">RELATED POSTS</p>
          <div class="related-grid">
            {relatedPosts.map(p => (
              <a href={`${base}/${lang}/blog/${p.slug}/`} class="related-card">
                <h4>{p.title}</h4>
                <p class="related-date">
                  <FormattedDate date={p.date} />
                </p>
                {p.description && <p class="related-desc">{p.description}</p>}
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    <!-- 목차 (우측) -->
    <aside class="toc" id="toc-container">
    <p class="toc-title">CONTENTS</p>
    <ul id="toc-list"></ul>
    </aside>
  </div>
</BaseLayout>

<script>
  (function () {
    const article = document.querySelector('.prose');
    const tocList = document.getElementById('toc-list');
    const tocContainer = document.getElementById('toc-container');

    if (!article || !tocList || !tocContainer) return;

    const headings = Array.from(
      article.querySelectorAll('h1, h2, h3, h4')
    ) as HTMLElement[];

    if (headings.length === 0) {
      tocContainer.style.display = 'none';
      return;
    }

    // id 없으면 자동 생성
    headings.forEach(h => {
      if (!h.id) {
        h.id = (h.textContent ?? '')
          .toLowerCase()
          .trim()
          .replace(/\s+/g, '-')
          .replace(/[^\w-]/g, '');
      }
    });

    // TOC 생성
    tocList.innerHTML = headings.map(h => {
      const depth = parseInt(h.tagName[1]);
      return `<li class="toc-item depth-${depth}">
        <a href="#${h.id}" class="toc-link" data-id="${h.id}">${h.textContent}</a>
      </li>`;
    }).join('');

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('.toc-link')
    );

    // 스크롤 하이라이트
    function onScroll() {
      let current = headings[0]?.id ?? '';
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= 120) current = h.id;
      }
      links.forEach(l => {
        l.classList.toggle('active', l.dataset.id === current);
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // 클릭 시 부드럽게 이동
    links.forEach(l => {
      l.addEventListener('click', e => {
        e.preventDefault();

    // 모든 링크 비활성화 후 클릭한 것만 활성화
        links.forEach(link => link.classList.remove('active'));
        l.classList.add('active');

        const id = l.dataset.id ?? '';
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  })();
</script>

<style>
  .post-wrap {
    display: flex;
    gap: 40px;
    align-items: flex-start;
  }
  .prose {
    flex: 1;
    min-width: 0;
    max-width: 720px;
  }
  .post-header { margin-bottom: 2rem; }
  .post-header h1 { font-size: 1.8rem; font-weight: 600; color: #e0e0e0; margin: 0 0 0.5rem; }
  .post-date { font-size: 0.78rem; color: #666; }
  .updated { color: #555; }
  .hero-image { width: 100%; border-radius: 8px; margin-bottom: 2rem; }

  /* 마크다운 본문 */
:global(.prose h1, .prose h2, .prose h3, .prose h4) {
  scroll-margin-top: 80px;
  }
  :global(.prose p) { color: #aaa; line-height: 1.8; margin-bottom: 1rem; }
  :global(.prose code) { background: #1e1e1e; padding: 2px 6px; border-radius: 4px; font-size: 0.85em; }
  :global(.prose pre) { background: #1a1a1a; padding: 1rem; border-radius: 8px; overflow-x: auto; margin-bottom: 1.5rem; }
  :global(.prose a) { color: #4a90d9; }

  /* 카테고리 + 태그 */
  .post-meta {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 0.5px solid #2a2a2a;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .meta-icon { color: #555; font-size: 0.8rem; }
  .meta-link { font-size: 0.78rem; color: #bbb; text-decoration: none; letter-spacing: 0.06em; }
  .meta-link:hover { color: #fff; }
  .tag-link { font-size: 0.78rem; color: #4a90d9; text-decoration: none; }
  .tag-link:hover { color: #7ab4f0; }

  /* 이전글/다음글 */
  .post-nav {
    display: flex;
    gap: 12px;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 0.5px solid #2a2a2a;
  }
  .nav-item { flex: 1; }
  .nav-item a {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
    padding: 12px;
    border: 0.5px solid #2a2a2a;
    border-radius: 8px;
    transition: border-color 0.2s;
  }
  .nav-item a:hover { border-color: #555; }
  .nav-item.next a { align-items: flex-end; }
  .nav-label { font-size: 0.7rem; color: #666; letter-spacing: 0.06em; }
  .nav-title { font-size: 0.82rem; color: #ccc; }
  .nav-empty { display: block; flex: 1; }

  /* 관련 포스트 */
  .related { margin-top: 2rem; padding-top: 1.5rem; border-top: 0.5px solid #2a2a2a; }
  .related-label { font-size: 0.7rem; color: #666; letter-spacing: 0.1em; margin-bottom: 1rem; }
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .related-card {
    display: block;
    text-decoration: none;
    padding: 14px;
    background: #1a1a1a;
    border: 0.5px solid #2a2a2a;
    border-radius: 8px;
    transition: border-color 0.2s;
  }
  .related-card:hover { border-color: #555; }
  .related-card h4 { font-size: 0.82rem; color: #e0e0e0; margin: 0 0 4px; font-weight: 500; }
  .related-date { font-size: 0.7rem; color: #666; margin: 0 0 6px; }
  .related-desc {
    font-size: 0.75rem; color: #888; margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 목차 */
  /* 목차 */
.toc {
  width: 180px;
  flex-shrink: 0;
  position: sticky;
  top: 28px;
  max-height: calc(100vh - 56px);
  overflow-y: auto;
}
.toc-title { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; color: #666; margin-bottom: 12px; }
:global(#toc-list) { list-style: none; padding: 0; margin: 0; border-left: 0.5px solid #2a2a2a; }
:global(.toc-item) { padding: 3px 0; }
:global(.depth-2) { padding-left: 12px; }
:global(.depth-3) { padding-left: 24px; }
:global(.depth-4) { padding-left: 36px; }
:global(.toc-link) {
  font-size: 0.75rem;
  color: #666;
  text-decoration: none;
  display: block;
  padding: 2px 8px;
  border-left: 2px solid transparent;
  margin-left: -1px;
  transition: color 0.2s, border-color 0.2s;
}
:global(.toc-link:hover) { color: #ccc; }
:global(.toc-link.active) { color: #4a90d9; border-left-color: #4a90d9; }
</style>