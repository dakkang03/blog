---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  currentLang: string;
  currentPath: string;
}
const { currentLang, currentPath } = Astro.props;
const targetLang = currentLang === 'en' ? 'ko' : 'en';
const targetUrl = `${base}/${targetLang}${currentPath}`;
---

<a href={targetUrl} class="toggle" aria-label="Switch language">
  <div class={`pill ${currentLang}`}>
    <span class="label-en">EN</span>
    <div class="dot"></div>
    <span class="label-ko">KO</span>
  </div>
</a>

<style>
  .toggle {
    text-decoration: none;
    cursor: pointer;
  }
  .pill {
    width: 64px;
    height: 30px;
    background: #5b6abf;
    border-radius: 999px;
    position: relative;
    display: flex;
    align-items: center;
    transition: background 0.2s;
    overflow: hidden;
  }
  .dot {
    width: 20px;
    height: 20px;
    background: #fff;
    border-radius: 50%;
    position: absolute;
    transition: left 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .label-en, .label-ko {
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    position: absolute;
    transition: opacity 0.2s;
    letter-spacing: 0.04em;
  }
  .label-en { left: 14px; }
  .label-ko { right: 14px; }

  /* EN*/
  .pill.en .dot { left: 40px; }
  .pill.en .label-en { opacity: 1; }
  .pill.en .label-ko { opacity: 0; }

  /* KO */
  .pill.ko .dot { left: 4px; }
  .pill.ko .label-en { opacity: 0; }
  .pill.ko .label-ko { opacity: 1; }
</style>