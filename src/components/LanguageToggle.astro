---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Props {
  currentLang: string;
  currentPath: string;
}
const { currentLang, currentPath } = Astro.props;
const targetLang = currentLang === 'en' ? 'ko' : 'en';
const targetUrl = `${base}/${targetLang}${currentPath}`;
---

<a href={targetUrl} class="toggle" aria-label="Switch language">
  <span class="lang-text">{currentLang.toUpperCase()}</span>
  <div class={`pill ${currentLang}`}>
    <div class="dot"></div>
  </div>
</a>

<style>
  .toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #222;
    border: 0.5px solid #444;
    border-radius: 999px;
    padding: 5px 6px 5px 12px;
    text-decoration: none;
    cursor: pointer;
  }
  .lang-text { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; color: #e0e0e0; }
  .pill {
    width: 32px; height: 18px;
    background: #4a90d9;
    border-radius: 999px;
    position: relative;
    transition: background 0.2s;
  }
  .dot {
    width: 12px; height: 12px;
    background: #fff;
    border-radius: 50%;
    position: absolute;
    top: 3px;
    transition: left 0.2s;
  }
  /* EN: 점이 오른쪽 */
  .pill.en .dot { left: 17px; }
  /* KO: 점이 왼쪽 */
  .pill.ko .dot { left: 3px; }
</style>