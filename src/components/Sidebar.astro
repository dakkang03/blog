---
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'ko';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('blog');
const langPosts = allPosts.filter(p => p.id.startsWith(`${lang}/`));

const categoryMap = new Map<string, number>();
langPosts.forEach(p => {
  if (p.data.category) {
    categoryMap.set(p.data.category, (categoryMap.get(p.data.category) ?? 0) + 1);
  }
});

const tagMap = new Map<string, number>();
langPosts.forEach(p => {
  (p.data.tags ?? []).forEach(tag => {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  });
});
---

<aside class="sidebar">
  <div class="profile">
    <a href={`${base}/${lang}/`}>
      <img src={`${base}/images/profile.jpg`} alt="Profile" class="avatar" />
    </a>
    <a href={`${base}/${lang}/`} class="blog-title">DAKKANG'S BLOG</a>
  </div>

<nav>
    <p class="nav-label">{t('sidebar.category')}</p>
    {categoryMap.size > 0
      ? [...categoryMap.entries()].map(([cat, count]) => (
          <a href={`${base}/${lang}/category/${cat}`} class="nav-row">
            <span>{cat.toUpperCase()}</span>
            <span class="count">{count}</span>
          </a>
        ))
      : <span class="empty">-</span>
    }
  </nav>

  <nav>
    <p class="nav-label">{t('sidebar.tag')}</p>
    {tagMap.size > 0
      ? [...tagMap.entries()].map(([tag, count]) => (
          <a href={`${base}/${lang}/tag/${tag}`} class="nav-row">
            <span>{tag.toUpperCase()}</span>
            <span class="count">{count}</span>
          </a>
        ))
      : <span class="empty">-</span>
    }
  </nav>

  <nav>
    <p class="nav-label">{t('sidebar.about')}</p>
    <a href="https://www.linkedin.com/in/dakyung-kang/" target="_blank">LINKED IN</a>
    <a href="https://github.com/dakkang03" target="_blank">GITHUB</a>
    <a href="https://dakkang03.github.io/" target="_blank">PORTFOLIO</a>
  </nav>
</aside>

<style>
  .sidebar {
    width: 200px;
    flex-shrink: 0;
    background: #161616;
    border-right: 0.5px solid #2a2a2a;
    padding: 28px 20px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
  }
  .profile { display: flex; flex-direction: column; align-items: center; gap: 25px; }
  .avatar { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; background: #333; }
  .blog-title { font-size: 18px; letter-spacing: 0.08em; color: #e0e0e0; text-align: center; text-decoration: none; }
  nav { display: flex; flex-direction: column; gap: 6px; }
  .nav-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  text-decoration: none;
  width: 98%;
  }
  .nav-label { font-size: 14px; font-weight: 600; letter-spacing: 0.12em; color: #666; margin-bottom: 2px; }
  a { font-size: 12px; letter-spacing: 0.06em; color: #bbb; text-decoration: none; }
  a:hover { color: #fff; }
  .empty { font-size: 11px; color: #444; }
</style>