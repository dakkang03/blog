---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const enPosts = posts.filter(p => p.id.startsWith('ko/'));
  const tags = [...new Set(enPosts.flatMap(p => p.data.tags ?? []))];

  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: enPosts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag: string;
  posts: CollectionEntry<'blog'>[];
}

const GRID_TAGS = ['시각화'];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'ko';
const { tag, posts } = Astro.props as { tag: string; posts: CollectionEntry<'blog'>[] };
const isGrid = GRID_TAGS.includes(tag);
const formatSlug = (id: string) => id.replace(/^ko\//, '').replace(/\.(md|mdx)$/, '');

function getFirstImage(body: string): string | null {
  const mdMatch = body.match(/!\[.*?\]\(([^)]+)\)/);
  if (mdMatch) return mdMatch[1];
  const htmlMatch = body.match(/<img[^>]+src=["']([^"']+)["']/);
  if (htmlMatch) return htmlMatch[1];
  return null;
}
---

<BaseLayout title={`#${tag}`} description={`Posts tagged ${tag}`}>
  <section>
    <h2>#{tag}</h2>

    {isGrid ? (
      <div class="card-grid">
        {posts.map((post) => {
          const imgSrc = post.data.heroImage as string | undefined
            ?? getFirstImage(post.body ?? '');
          return (
            <article class="card">
              <a href={`${base}/ko/blog/${formatSlug(post.id)}/`} class="card-link">
                <div class="card-image">
                  {imgSrc
                    ? <img src={imgSrc} alt={post.data.title} />
                    : <div class="card-image-placeholder">IMAGE</div>
                  }
                </div>
                <div class="card-body">
                  <h3 class="card-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="card-desc">{post.data.description}</p>
                  )}
                  <span class="card-date"><FormattedDate date={post.data.pubDate} /></span>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`${base}/ko/blog/${formatSlug(post.id)}/`}>
              <h4 class="post-title">{post.data.title}</h4>
              <p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  h2 {
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }
  :global(.post-list) { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  :global(.post-item) { padding: 1.2rem 0; border-top: 1.3px solid var(--border-color); }
  :global(.post-item:last-child) { border-bottom: 1.3px solid var(--border-color); }
  :global(.post-item a) { text-decoration: none; display: block; }
  :global(.post-title) { font-size: 1.3rem; font-weight: 500; color: var(--text-primary); margin: 0 0 0.3rem; }
  :global(.post-date) { font-size: 0.85rem; color: var(--text-subtle); margin: 0 0 0.5rem; }
  :global(.post-excerpt) {
    font-size: 0.95rem; color: var(--text-muted); margin: 0 0 0.5rem; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  :global(.post-tags) { display: flex; gap: 6px; flex-wrap: wrap; }
  :global(.tag) { font-size: 0.8rem; color: var(--accent); }
  :global(.post-item a:hover .post-title) { color: var(--text-primary); filter: brightness(1.3); }
  .pagination { display: flex; align-items: center; justify-content: center; gap: 4px; margin-top: 2rem; padding-top: 1.5rem; }
  :global(.pag-num) { color: var(--text-muted); font-size: 0.82rem; padding: 4px 8px; border-radius: 4px; cursor: pointer; }
  :global(.pag-num:hover) { color: var(--text-primary); }
  :global(.pag-num.active) { color: var(--text-primary); font-weight: 500; background: var(--bg-card); }
  :global(.pag-arrow) { font-size: 2rem; color: var(--text-muted); padding: 4px 6px; cursor: pointer; }
  :global(.pag-arrow:hover) { color: var(--text-primary); }
  :global(.pag-arrow.disabled) { opacity: 0.3; cursor: default; }
</style>