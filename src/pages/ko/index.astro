---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { useTranslations } from '../../i18n/utils';

const lang = 'ko' as const;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.id.startsWith('ko/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatSlug = (id: string) =>
  id.replace(/^ko\//, '').replace(/\.(md|mdx)$/, '');

const postsData = posts.map((p) => ({
  slug: formatSlug(p.id),
  title: p.data.title,
  date: p.data.pubDate.toISOString(),
  description: p.data.description ?? '',
  tags: p.data.tags ?? [],
}));
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section>
    <h2>{t('home.recentPosts')}</h2>
    <ul class="post-list" id="post-list"></ul>
    <nav class="pagination" id="pagination"></nav>
  </section>
</BaseLayout>

<script define:vars={{ postsData, base }}>
  const PAGE_SIZE = 10;

  function formatDate(iso) {
    return new Date(iso).toLocaleDateString('ko-KR', {
      year: 'numeric', month: 'long', day: 'numeric',
    });
  }

  function render(page) {
    const total = Math.ceil(postsData.length / PAGE_SIZE);
    const start = (page - 1) * PAGE_SIZE;
    const slice = postsData.slice(start, start + PAGE_SIZE);

    document.getElementById('post-list').innerHTML = slice.map(p => `
      <li class="post-item">
        <a href="${base}/ko/blog/${p.slug}/">
          <h4 class="post-title">${p.title}</h4>
          <p class="post-date">${formatDate(p.date)}</p>
          ${p.description ? `<p class="post-excerpt">${p.description}</p>` : ''}
          ${p.tags.length > 0
            ? `<div class="post-tags">${p.tags.map(tag => `<span class="tag">#${tag}</span>`).join('')}</div>`
            : ''}
        </a>
      </li>
    `).join('');

    document.getElementById('pagination').innerHTML = `
      <span class="pag-arrow ${page === 1 ? 'disabled' : ''}"
        onclick="${page > 1 ? `goTo(${page - 1})` : ''}">&#8249;</span>
      ${Array.from({ length: total }, (_, i) => i + 1).map(n => `
        <span class="pag-num ${n === page ? 'active' : ''}" onclick="goTo(${n})">${n}</span>
      `).join('')}
      <span class="pag-arrow ${page === total ? 'disabled' : ''}"
        onclick="${page < total ? `goTo(${page + 1})` : ''}">&#8250;</span>
    `;
  }

  window.goTo = function(page) {
    render(page);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  render(1);
</script>

<style>
  h2 {
    font-size: 1.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }
  :global(.post-list) { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; }
  :global(.post-item) { padding: 1.2rem 0; border-top: 1.3px solid var(--border-color); }
  :global(.post-item:last-child) { border-bottom: 1.3px solid var(--border-color); }
  :global(.post-item a) { text-decoration: none; display: block; }
  :global(.post-title) { font-size: 1.3rem; font-weight: 500; color: var(--text-primary); margin: 0 0 0.3rem; }
  :global(.post-date) { font-size: 0.85rem; color: var(--text-subtle); margin: 0 0 0.5rem; }
  :global(.post-excerpt) {
    font-size: 0.95rem; color: var(--text-muted); margin: 0 0 0.5rem; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  :global(.post-tags) { display: flex; gap: 6px; flex-wrap: wrap; }
  :global(.tag) { font-size: 0.8rem; color: var(--accent); }
  :global(.post-item a:hover .post-title) { color: var(--text-primary); filter: brightness(1.3); }
  .pagination { display: flex; align-items: center; justify-content: center; gap: 4px; margin-top: 2rem; padding-top: 1.5rem; }
  :global(.pag-num) { color: var(--text-muted); font-size: 0.82rem; padding: 4px 8px; border-radius: 4px; cursor: pointer; }
  :global(.pag-num:hover) { color: var(--text-primary); }
  :global(.pag-num.active) { color: var(--text-primary); font-weight: 500; background: var(--bg-card); }
  :global(.pag-arrow) { font-size: 2rem; color: var(--text-muted); padding: 4px 6px; cursor: pointer; }
  :global(.pag-arrow:hover) { color: var(--text-primary); }
  :global(.pag-arrow.disabled) { opacity: 0.3; cursor: default; }
</style>