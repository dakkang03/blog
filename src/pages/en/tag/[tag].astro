---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormattedDate from '../../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const enPosts = posts.filter(p => p.id.startsWith('en/'));
  const tags = [...new Set(enPosts.flatMap(p => p.data.tags ?? []))];

  return tags.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: enPosts
        .filter(p => p.data.tags?.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

interface Props {
  tag: string;
  posts: CollectionEntry<'blog'>[];
}

const GRID_TAGS = ['visualize'];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const lang = 'en';
const { tag, posts } = Astro.props as { tag: string; posts: CollectionEntry<'blog'>[] };
const isGrid = GRID_TAGS.includes(tag);
const formatSlug = (id: string) => id.replace(/^en\//, '').replace(/\.(md|mdx)$/, '');

function getFirstImage(body: string): string | null {
  const mdMatch = body.match(/!\[.*?\]\(([^)]+)\)/);
  if (mdMatch) return mdMatch[1];
  const htmlMatch = body.match(/<img[^>]+src=["']([^"']+)["']/);
  if (htmlMatch) return htmlMatch[1];
  return null;
}
---

<BaseLayout title={`#${tag}`} description={`Posts tagged ${tag}`}>
  <section>
    <h2>#{tag}</h2>

    {isGrid ? (
      <div class="card-grid">
        {posts.map((post) => {
          const imgSrc = post.data.heroImage as string | undefined
            ?? getFirstImage(post.body ?? '');
          return (
            <article class="card">
              <a href={`${base}/en/blog/${formatSlug(post.id)}/`} class="card-link">
                <div class="card-image">
                  {imgSrc
                    ? <img src={imgSrc} alt={post.data.title} />
                    : <div class="card-image-placeholder">IMAGE</div>
                  }
                </div>
                <div class="card-body">
                  <h3 class="card-title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="card-desc">{post.data.description}</p>
                  )}
                  <span class="card-date"><FormattedDate date={post.data.pubDate} /></span>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <a href={`${base}/en/blog/${formatSlug(post.id)}/`}>
              <h4 class="post-title">{post.data.title}</h4>
              <p class="post-date"><FormattedDate date={post.data.pubDate} /></p>
              {post.data.description && (
                <p class="post-excerpt">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  h2 { font-size: 1.4rem; font-weight: 700; letter-spacing: 0.06em; color: var(--accent); margin-bottom: 2rem; }

  /* 그리드 */
  .card-grid { display: grid; grid-template-columns: repeat(10, 280px); gap: 20px; }
  .card {
    background: var(--bg-card);
    border: 0.5px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
    height: 300px;
  }
  .card-body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    height: calc(300px - 180px);
    overflow: hidden;
  }
  .card:hover { border-color: var(--border-hover); transform: translateY(-2px); }
  .card-link { text-decoration: none; display: block; }
  .card-image { width: 100%; height: 180px; overflow: hidden; background: var(--bg-image); }
  .card-image img { width: 100%; height: 100%; object-fit: cover; }
  .card-image-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-subtle); font-size: 0.85rem; letter-spacing: 0.1em; }
  .card-title { font-size: 0.95rem; font-weight: 500; color: var(--text-primary); margin: 0; line-height: 1.4; }
  .card-date { font-size: 0.72rem; color: var(--text-subtle); }
  .card-desc {
    font-size: 0.78rem; color: var(--text-muted); margin: 0; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* 리스트 */
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-item { padding: 1.2rem 0; border-top: 1.3px solid var(--border-color); }
  .post-item:last-child { border-bottom: 1.3px solid var(--border-color); }
  .post-item a { text-decoration: none; display: block; }
  .post-title { font-size: 0.95rem; font-weight: 500; color: var(--text-primary); margin: 0 0 0.3rem; }
  .post-date { font-size: 0.75rem; color: var(--text-subtle); margin: 0 0 0.5rem; }
  .post-excerpt { font-size: 0.82rem; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .post-item a:hover .post-title { color: var(--text-primary); filter: brightness(1.3); }
</style>